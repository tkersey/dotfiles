{
  "mcpServers": {
    "mcp-installer": {
      "command": "npx",
      "args": ["@anaisbetts/mcp-installer"]
    },
    "XcodeBuildMCP": {
      "command": "mise",
      "args": ["x", "npm:xcodebuildmcp@latest", "--", "xcodebuildmcp"]
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "mcp-hn": {
      "command": "uvx",
      "args": ["mcp-hn"]
    },
    "atlassian": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.atlassian.com/v1/sse"]
    }
  }
}
