{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example/agent-ergo/applied_changes.schema.json",
  "title": "audit/applied_changes.jsonl record",
  "description": "Phase 5 output. One record per applied recommendation. Source: IO-CONTRACTS.md § audit/applied_changes.jsonl",
  "type": "object",
  "required": ["recommendation_id", "pass", "commit_sha", "files_changed", "applied_at"],
  "properties": {
    "recommendation_id": {"type": "string", "pattern": "^R-[0-9]{3,4}(\\.[a-zA-Z0-9_-]+)?$"},
    "pass": {"type": "integer", "minimum": 1},
    "bead_id": {"type": "string"},
    "commit_sha": {"type": "string", "pattern": "^[0-9a-f]{7,40}$"},
    "files_changed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {"type": "string"},
          "before_excerpt": {"type": "string"},
          "after_excerpt": {"type": "string"},
          "lines_added": {"type": "integer", "minimum": 0},
          "lines_removed": {"type": "integer", "minimum": 0}
        }
      }
    },
    "surface_ids_touched": {"type": "array", "items": {"type": "string"}},
    "test_path": {"type": "string"},
    "applied_at": {"type": "string", "format": "date-time"}
  }
}
