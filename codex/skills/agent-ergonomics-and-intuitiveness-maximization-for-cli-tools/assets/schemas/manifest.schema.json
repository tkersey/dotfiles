{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example/agent-ergo/manifest.schema.json",
  "title": "audit/manifest.json",
  "description": "Top-level workspace state. Source of truth: references/methodology/IO-CONTRACTS.md § audit/manifest.json",
  "type": "object",
  "required": ["schema_version", "tool_name", "tool_repo", "audit_workspace", "current_pass", "passes"],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "tool_name": {"type": "string", "minLength": 1},
    "tool_repo": {"type": "string", "minLength": 1, "description": "Absolute path to the target CLI repo"},
    "audit_workspace": {"type": "string", "minLength": 1, "description": "Absolute path to the sibling audit workspace"},
    "rubric_version": {"type": "string"},
    "current_pass": {"type": "integer", "minimum": 1},
    "pass_N+1_ready": {"type": "boolean"},
    "next_pass_focus": {"type": ["string", "null"]},
    "cost_cap": {
      "type": "object",
      "properties": {
        "max_subagents": {"type": "integer", "minimum": 0},
        "max_minutes": {"type": "integer", "minimum": 0},
        "max_usd_estimated": {"type": "number", "minimum": 0},
        "per_phase": {
          "type": "object",
          "description": "Per-phase caps keyed by phase number as a string ('0'..'10'). Override the corresponding global cap when --phase is passed to tools/cost-cap.sh.",
          "patternProperties": {
            "^[0-9]+$": {
              "type": "object",
              "properties": {
                "max_subagents": {"type": "integer", "minimum": 0},
                "max_minutes":   {"type": "integer", "minimum": 0}
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "passes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pass", "started_at", "summary", "artifacts"],
        "properties": {
          "pass": {"type": "integer", "minimum": 1},
          "started_at": {"type": "string", "format": "date-time"},
          "completed_at": {"type": ["string", "null"]},
          "mode": {"type": ["string", "null"], "enum": ["mini", "audit-only", "full", "re-score-only", "simulate-only", "single-surface-rescore", null]},
          "target_sha": {"type": "string"},
          "feature_branch": {"type": ["string", "null"]},
          "summary": {
            "type": "object",
            "properties": {
              "surfaces_inventoried": {"type": "integer", "minimum": 0},
              "surfaces_scored": {"type": "integer", "minimum": 0},
              "recommendations_total": {"type": "integer", "minimum": 0},
              "recommendations_applied": {"type": "integer", "minimum": 0},
              "median_uplift_pts": {"type": "integer"},
              "regressions_count": {"type": "integer", "minimum": 0},
              "fresh_eyes_rounds": {"type": "integer", "minimum": 0},
              "subagents_spawned": {"type": "integer", "minimum": 0}
            }
          },
          "phase_summary": {
            "type": "object",
            "description": "Per-phase counters (subagents_spawned, started_at) keyed by phase number as a string. Read by tools/cost-cap.sh --phase.",
            "patternProperties": {
              "^[0-9]+$": {
                "type": "object",
                "properties": {
                  "started_at": {"type": "string", "format": "date-time"},
                  "subagents_spawned": {"type": "integer", "minimum": 0}
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          "artifacts": {"type": "object"}
        }
      }
    }
  }
}
