{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example/agent-ergo/recommendations_clustered.schema.json",
  "title": "audit/recommendations.clustered.jsonl record",
  "description": "Output of scripts/cluster-recommendations.sh. One record per cluster of near-duplicate recommendations.",
  "type": "object",
  "required": ["cluster_id", "canonical_recommendation_id", "title", "member_recommendation_ids", "surface_ids", "members_count", "surfaces_count"],
  "properties": {
    "cluster_id": {"type": "string", "pattern": "^C-[0-9]{2,3}$"},
    "canonical_recommendation_id": {"type": "string", "pattern": "^R-[0-9]{3,4}(\\.[a-zA-Z0-9_-]+)?$"},
    "title": {"type": "string", "minLength": 1},
    "member_recommendation_ids": {
      "type": "array",
      "items": {"type": "string", "pattern": "^R-[0-9]{3,4}(\\.[a-zA-Z0-9_-]+)?$"},
      "minItems": 1
    },
    "surface_ids": {
      "type": "array",
      "items": {"type": "string"}
    },
    "touched_dims": {
      "type": "array",
      "items": {"type": "string"}
    },
    "expected_uplift_total": {"type": "integer", "minimum": 0, "maximum": 1000},
    "anchor_pattern": {"type": "string"},
    "members_count": {"type": "integer", "minimum": 1},
    "surfaces_count": {"type": "integer", "minimum": 0}
  }
}
