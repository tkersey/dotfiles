{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example/agent-ergo/intent_inference_corpus.schema.json",
  "title": "audit/intent_inference_corpus.jsonl record",
  "description": "Phase 3 output. One record per attempted invocation. Source: IO-CONTRACTS.md § audit/intent_inference_corpus.jsonl",
  "type": "object",
  "required": ["corpus_id", "generator", "category", "argv", "mutates", "safe_to_run", "predicted_outcome", "stresses_surface_id", "reason"],
  "properties": {
    "corpus_id": {"type": "string", "minLength": 1},
    "generator": {"type": "string", "enum": ["naive", "savvy"]},
    "category": {"type": "string", "minLength": 1},
    "argv": {"type": "array", "items": {"type": "string"}, "minItems": 1, "description": "argv[0] is replaced by <TOOL> at runtime"},
    "invocation": {"type": "string", "description": "Display-only when argv is present"},
    "cwd": {"type": ["string", "null"]},
    "env": {"type": "object", "description": "Extra env vars merged on top of NO_COLOR=1, TERM=dumb, CI=true"},
    "mutates": {"type": "boolean"},
    "safe_to_run": {"type": "boolean"},
    "predicted_outcome": {"type": "string", "enum": ["silent_fail", "useless_error", "useful_hint", "inferred_and_acted", "skipped"]},
    "classification": {"type": "string", "enum": ["silent_fail", "useless_error", "useful_hint", "inferred_and_acted", "skipped"]},
    "skip_reason": {"type": ["string", "null"]},
    "matched_predicted": {"type": "boolean"},
    "stresses_surface_id": {"type": "string"},
    "stdout": {"type": "string"},
    "stderr": {"type": "string"},
    "exit_code": {"type": "integer"},
    "reason": {"type": "string"},
    "cites": {"type": "array", "items": {"type": "string"}, "description": "Populated by savvy generator only"},
    "generated_at": {"type": "string", "format": "date-time"},
    "ran_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {
      "if": {"properties": {"mutates": {"const": true}}},
      "then": {"description": "Mutating entries MUST also have safe_to_run; the runner skips them otherwise."}
    }
  ]
}
