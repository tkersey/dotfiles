#!/usr/bin/env python3
"""bad-cli: a deliberately-bad CLI for skill regression testing.

Each anti-pattern is labeled `# AP-NNN` with a brief reason. The skill should
detect every labeled anti-pattern when run against this binary. The
ground-truth list is in ANTI-PATTERNS.md alongside this file.

Run `./badcli --help` to see the interface (such as it is).

Authoring discipline:
- Every anti-pattern must be UNAMBIGUOUSLY observable from the binary's
  behavior or output. No hidden anti-patterns, no things that require source
  reading. The skill must be able to detect via help/runtime evidence.
- Every anti-pattern must clearly violate ONE specific dim. Multi-dim
  violations are noted but counted as the dim with the strongest violation.
- The CLI must still EXECUTE without crashing on common inputs. We're testing
  the skill's pattern-detection, not its crash recovery.
"""
import sys
import os

# AP-001 (self_documentation): generic usage message; no real --help text.
USAGE = "badcli [args]"

# AP-002 (composability): hardcoded color always; no NO_COLOR honor.
RED = "\033[31m"
RESET = "\033[0m"


def cmd_list(args):
    # AP-003 (output_parseability): no --json mode for a clearly-listable verb.
    # AP-004 (determinism_and_reproducibility): output uses random insertion order.
    items = ["alpha", "beta", "gamma"]
    import random
    random.shuffle(items)
    for item in items:
        print(f"{RED}* {item}{RESET}")


def cmd_get(args):
    if not args:
        # AP-005 (error_pedagogy): error message provides no diagnosis or fix.
        print("ERROR", file=sys.stderr)
        # AP-006 (agent_ease_of_use): exits 0 on a clear error condition.
        sys.exit(0)
    print(f"got: {args[0]}")


def cmd_delete(args):
    # AP-007 (safety_with_recovery): destructive verb with no --dry-run.
    # AP-008 (safety_with_recovery): destructive verb with no confirmation prompt.
    if args:
        print(f"deleted {args[0]}")
        # AP-009 (regression_resistance): no audit log written.


def cmd_status(args):
    # AP-010 (output_parseability): printf-style ad-hoc format, no separator.
    # AP-011 (intent_inference): no flag to select machine-readable output.
    print("status: OK time: 12:34:56 mode: production count: 42")


def cmd_lits(args):
    # AP-012 (intent_inference): close-typo of "list" — should suggest "did you mean list?"
    # but instead just errors generically (see main).
    raise NotImplementedError


# AP-013 (intent_inference): camelCase verb in a tool that otherwise uses lowercase
def cmd_GetAll(args):
    print("got all")


def main():
    args = sys.argv[1:]
    if not args:
        # AP-014 (self_documentation): bare invocation prints usage to stdout, exits 0.
        # Real tools emit usage to stderr and exit non-zero so wrappers can detect "no input".
        print(USAGE)
        sys.exit(0)

    # AP-015 (intent_inference): unknown verbs / flags get a generic error
    # with no levenshtein-1 hint.
    flag_first = args[0].startswith("-")
    if flag_first:
        # AP-016 (self_documentation): --help is unrecognized as a flag.
        # AP-017 (intent_inference): --version doesn't exist.
        print(f"unknown flag: {args[0]}", file=sys.stderr)
        sys.exit(2)

    verb = args[0]
    handlers = {
        "list": cmd_list,
        "get": cmd_get,
        "delete": cmd_delete,
        "status": cmd_status,
        "lits": cmd_lits,
        "GetAll": cmd_GetAll,
    }
    h = handlers.get(verb)
    if not h:
        # AP-018 (error_pedagogy): unknown-verb error without listing valid verbs.
        print(f"unknown verb: {verb}", file=sys.stderr)
        sys.exit(2)

    try:
        h(args[1:])
    except Exception as e:
        # AP-019 (error_pedagogy): exception leaks Python traceback to user.
        # AP-020 (safety_with_recovery): no cleanup of partial state on error.
        raise


# AP-021 (regression_resistance): no test suite exists for this CLI.
# AP-022 (agent_intuitiveness): no man page, no shell completions, no docs URL.
# AP-023 (composability): no exit code spec in help.

if __name__ == "__main__":
    main()
