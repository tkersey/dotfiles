#!/usr/bin/env bash
# bin/aerg — Single entry point for the agent-ergonomics audit skill.
#
# This wrapper dispatches to skill scripts/tools with stable arg ordering, so
# users (and AI agents) can write `aerg dryrun ./bv` instead of the much
# longer `bash $SKILL/scripts/dryrun-llm.sh ./bv`. No business logic lives
# here — just dispatch + a help text organized for first-time discoverability.
#
# FIRST TIME? Run `aerg quickstart` for the canonical 3-command flow.
#
# ─── Verbs by workflow stage ────────────────────────────────────────────────
#
# Start here:
#   quickstart    Print the canonical 3-command first-run flow + cost estimate
#   preflight     Verify environment + target before starting an audit
#   preview       30-second dry-run: inventory + estimate, no LLM calls
#   estimate      Cost & time estimate for a full pass against <target>
#
# Run the audit (cheap → expensive):
#   dryrun        Run the LLM scorer on a small sample (--mode stub|claude)
#                 — THE entry point for trying the skill on real data.
#                 Stub mode is free + offline; claude mode invokes real API.
#
# Inspect results:
#   explain       Why did this surface get this score? (`aerg explain <sibling> <surface_id>`)
#                 Add `--rec <rec_id>` after sibling to explain a recommendation instead.
#   compare       Diff two audit workspaces (`aerg compare <A> <B>`)
#   replay        Replay an old audit's recommendations against current source
#   telemetry     Per-subagent cost + duration summary
#
# Maintenance:
#   doctor        Health-check an audit workspace (orphan locks, schema drift)
#   gc            Garbage-collect old partials / dryruns (--plan default)
#   calibrate     Run rubric calibration against an expert corpus
#   archetype     Validate that CLI archetypes are meaningful clusters
#
# Misc:
#   audit         Alias for `preflight` (kept for backwards compat). Use
#                 `preflight` for clarity — this verb does NOT run the
#                 full audit, only the pre-flight environment check.
#   help          Show this message
#
# ─── Conventions ────────────────────────────────────────────────────────────
#
# Pass `--skill-path PATH` as the FIRST argument to override skill location;
# default is the directory containing this script's parent. `aerg help <verb>`
# is not implemented — pass `--help` to the dispatched script directly:
# `aerg dryrun --help` works.
set -euo pipefail

# Resolve skill root: by default, parent of this script's directory.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_ROOT="$(dirname "$SCRIPT_DIR")"

if [ "${1:-}" = "--skill-path" ]; then
  [ -z "${2:-}" ] && { echo "--skill-path requires a value" >&2; exit 2; }
  SKILL_ROOT="$2"
  shift 2
fi

usage() {
  /usr/bin/awk '/^# bin\/aerg/{flag=1} /^set -e/{exit} flag{print}' "${BASH_SOURCE[0]}" \
    | sed 's/^# \{0,1\}//'
}

# `aerg quickstart` prints a canonical first-run flow with copy-paste commands.
quickstart() {
  cat <<'EOF'
# Agent-ergonomics audit — quickstart

You're auditing a CLI tool's ergonomics for AI agents. Three commands take you
from cold-context to "should I run a real audit?" in under 5 minutes:

  ## 1. Verify the environment + target.
  aerg preflight /path/to/your/target/repo

  ## 2. See what the audit WOULD cost / look like (no LLM spend).
  aerg preview $(which mytool)

  ## 3. Run the LLM scorer on 4 surfaces in stub mode (offline, free).
  aerg dryrun /path/to/your/audit/sibling --surfaces 4 --mode stub

If all three pass, you've validated the harness and can move to:

  ## 4. Real LLM scoring — small batch, budgeted.
  aerg dryrun /path/to/your/audit/sibling --surfaces 10 --mode claude --budget-usd 5

The parent agent (you) spawns the printed scorer prompts via your Task tool,
then re-runs aggregate_scores.sh + dryrun-verify.sh against the same workdir.

DOCS:
  - references/CHEAT-SHEET.md           — dense single-page reference
  - references/REAL-AUDIT-CHECKLIST.md  — first-real-audit walkthrough +
                                          dogfood lessons (pre-empts traps)
  - SKILL.md                            — full methodology (752 lines)
EOF
}

if [ "$#" -eq 0 ]; then usage; exit 0; fi
verb="$1"; shift

run() {
  local script="$1"; shift
  if [ ! -x "$script" ]; then
    echo "aerg: missing or non-executable: $script" >&2
    exit 2
  fi
  exec bash "$script" "$@"
}

case "$verb" in
  -h|--help|help) usage; exit 0 ;;

  quickstart) quickstart; exit 0 ;;

  preflight)
    run "$SKILL_ROOT/scripts/preflight.sh" "$@"
    ;;

  audit)
    # Backwards-compat alias for `preflight`. Print a one-line note so users
    # discover the rename without having their automation break.
    echo "aerg: 'audit' is an alias for 'preflight'. The verb checks the environment;" >&2
    echo "      it does NOT run the full audit. To start a real audit, see 'aerg quickstart'." >&2
    run "$SKILL_ROOT/scripts/preflight.sh" "$@"
    ;;

  estimate)
    run "$SKILL_ROOT/scripts/estimate.sh" "$@"
    ;;

  preview)
    # "preview" runs inventory + estimate + (skipped) discovery, no LLM calls.
    if [ -z "${1:-}" ]; then
      echo "Usage: aerg preview <target-binary> [--depth N]" >&2; exit 2
    fi
    target="$1"; shift
    echo "# Preview"
    echo
    echo "## Inventory"
    bash "$SKILL_ROOT/scripts/inventory_surfaces.sh" "$target" "$@" | wc -l | xargs printf 'Surfaces discovered: %s\n'
    echo
    echo "## Estimate"
    bash "$SKILL_ROOT/scripts/estimate.sh" "$target" "$@" 2>/dev/null || true
    ;;

  dryrun)
    # The proven LLM-scorer entry point. Defaults to stub mode (offline, free).
    run "$SKILL_ROOT/scripts/dryrun-llm.sh" "$@"
    ;;

  explain)
    # explain <sibling> <surface_id>
    # explain <sibling> --rec <rec_id>
    # Old form (--rec FIRST) is also accepted for backwards compatibility.
    if [ "${1:-}" = "--rec" ]; then
      shift
      run "$SKILL_ROOT/tools/explain-rec.sh" "$@"
    elif [ "${2:-}" = "--rec" ]; then
      sibling="$1"; shift 2
      run "$SKILL_ROOT/tools/explain-rec.sh" "$sibling" "$@"
    else
      run "$SKILL_ROOT/tools/explain-score.sh" "$@"
    fi
    ;;

  doctor)
    run "$SKILL_ROOT/tools/audit-doctor.sh" "$@"
    ;;

  compare)
    run "$SKILL_ROOT/tools/audit-compare.sh" "$@"
    ;;

  replay)
    run "$SKILL_ROOT/scripts/audit-replay.sh" "$@"
    ;;

  calibrate)
    run "$SKILL_ROOT/scripts/rubric-calibrate.sh" "$@"
    ;;

  archetype)
    run "$SKILL_ROOT/scripts/archetype-calibrate.sh" "$@"
    ;;

  telemetry)
    run "$SKILL_ROOT/tools/telemetry-summary.sh" "$@"
    ;;

  gc)
    run "$SKILL_ROOT/scripts/workspace-gc.sh" "$@"
    ;;

  *)
    echo "aerg: unknown verb '$verb'" >&2
    echo "      run 'aerg help' for usage, or 'aerg quickstart' if you're new" >&2
    # Levenshtein-1 typo correction (per REC-PATTERNS Pattern-1).
    # Strings passed as argv (NOT interpolated into the python source) so the
    # verb cannot inject python code via apostrophes / quotes / backticks.
    suggestions=$(python3 - "$verb" \
      quickstart preflight audit estimate preview dryrun \
      explain doctor compare replay calibrate archetype \
      telemetry gc help <<'PY'
import sys

def lev(a, b, cache=None):
    if cache is None: cache = {}
    if (a, b) in cache: return cache[(a, b)]
    if not a: return len(b)
    if not b: return len(a)
    if a[0] == b[0]:
        r = lev(a[1:], b[1:], cache)
    else:
        r = 1 + min(lev(a[1:], b, cache), lev(a, b[1:], cache), lev(a[1:], b[1:], cache))
    cache[(a, b)] = r
    return r

verb = sys.argv[1]
for cand in sys.argv[2:]:
    if abs(len(verb) - len(cand)) > 1:
        continue
    if lev(verb, cand) <= 1:
        print(cand)
PY
)
    if [ -n "$suggestions" ]; then
      while IFS= read -r s; do
        [ -n "$s" ] && echo "      did you mean: aerg $s?" >&2
      done <<< "$suggestions"
    fi
    exit 2
    ;;
esac
