        "knowledge_routes": {
          "type": "array"
        },
        "negative_routes": {
          "type": "array"
        },
        "next_actions": {
          "type": "array"
        },
        "open_questions": {
          "type": "array"
        },
        "owned_invariants": {
          "type": "array"
        },
        "proof_map": {
          "type": "object"
        },
        "rejected_skill_candidates": {
          "type": "array"
        },
        "repository_fingerprint": {
          "type": "object"
