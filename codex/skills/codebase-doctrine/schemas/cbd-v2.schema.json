          "type": [
            "object",
            "null"
          ]
        },
        "request": {
          "type": "object"
        },
        "saturation": {
          "type": "object"
        },
        "search_ledger": {
          "type": "array"
        },
        "specialist_receipts": {
          "type": "array"
        },
        "system_map": {
          "type": "object"
        }
