        "authority_map": {
          "type": "object"
        },
        "behavioral_model": {
          "type": "object"
        },
        "boundary_rules": {
          "type": "array"
        },
        "claims": {
          "type": "array"
        },
        "confidence": {
          "type": "object"
        },
        "contradictions": {
          "type": "array"
        },
        "doctrine_id": {
          "minLength": 1,
