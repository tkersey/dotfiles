        "repository_fingerprint",
        "system_map",
        "authority_map",
        "behavioral_model",
        "governing_laws",
        "owned_invariants",
        "boundary_rules",
        "failure_families",
        "negative_routes",
        "proof_map",
        "contradictions",
        "open_questions",
        "knowledge_routes",
        "repository_root_skill",
        "focused_skill_candidates",
        "rejected_skill_candidates",
        "specialist_receipts",
        "saturation",
        "confidence",
        "next_actions"
