        },
        "doctrine_version": {
          "const": "CBD-v2"
        },
        "evidence_index": {
          "type": "array"
        },
        "failure_families": {
          "type": "array"
        },
        "focused_skill_candidates": {
          "type": "array"
        },
        "governing_laws": {
          "type": "array"
