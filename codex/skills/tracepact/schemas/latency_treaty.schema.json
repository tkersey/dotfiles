{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/latency_treaty.schema.json",
  "title": "Latency Treaty IR",
  "type": "object",
  "required": ["version", "operations"],
  "additionalProperties": true,
  "properties": {
    "version": {"type": "string"},
    "trace_id": {"type": ["string", "null"]},
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "operation", "kind", "critical_role"],
        "additionalProperties": true,
        "properties": {
          "id": {"type": "string"},
          "operation": {"type": "string"},
          "kind": {"type": "string"},
          "provider_offer": {"type": "string"},
          "morphism_offers": {"type": "array", "items": {"type": "string"}},
          "observed_route": {"type": "string"},
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "dependency_reasons": {"type": "object", "additionalProperties": {"type": "string"}},
          "usage_policy": {"type": "string"},
          "freshness_policy": {"type": "string"},
          "authority_policy": {"type": "string"},
          "branch_policy": {"type": "string"},
          "cache_replay_policy": {"type": "string"},
          "critical_role": {
            "type": "string",
            "enum": ["causal_witness", "movable_witness", "treaty_blocker", "policy_artifact", "coordination_waste", "unknown"]
          },
          "rewrite_legality": {"type": "string"},
          "proof_needed": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "counterfactual_schedules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "rewrite", "legality"],
        "properties": {
          "name": {"type": "string"},
          "rewrite": {"type": "string"},
          "legality": {"type": "string"},
          "estimated_savings_ms": {"type": ["number", "null"]},
          "risk": {"type": "string"},
          "validation": {"type": "string"}
        }
      }
    }
  }
}
