#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=codex/skills/auto/scripts/auto-lib.sh
. "$SCRIPT_DIR/auto-lib.sh"

usage() {
  cat <<'TEXT'
Usage:
  auto-optimize-one prepare --skill NAME --evidence-class CLASS --problem-slug SLUG --evidence-summary TEXT
  auto-optimize-one finalize --skill NAME --evidence-class CLASS --problem-slug SLUG --evidence-summary TEXT [--repair-attempted]
TEXT
}

[ "$#" -ge 1 ] || { usage; exit 2; }
PHASE="$1"
shift

SKILL=""
EVIDENCE_CLASS=""
PROBLEM_SLUG=""
SUMMARY=""
REPAIR_ATTEMPTED=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --skill) [ "$#" -ge 2 ] || auto_die "--skill requires a value"; SKILL="$2"; shift 2 ;;
    --evidence-class) [ "$#" -ge 2 ] || auto_die "--evidence-class requires a value"; EVIDENCE_CLASS="$2"; shift 2 ;;
    --problem-slug) [ "$#" -ge 2 ] || auto_die "--problem-slug requires a value"; PROBLEM_SLUG="$(auto_slugify "$2")"; shift 2 ;;
    --evidence-summary) [ "$#" -ge 2 ] || auto_die "--evidence-summary requires a value"; SUMMARY="$(auto_sanitize_summary "$2")"; shift 2 ;;
    --repair-attempted) REPAIR_ATTEMPTED=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) auto_die "unknown argument: $1" ;;
  esac
done

[ -n "$SKILL" ] || auto_die "--skill is required"
[ -n "$EVIDENCE_CLASS" ] || auto_die "--evidence-class is required"
[ -n "$PROBLEM_SLUG" ] || auto_die "--problem-slug is required"
[ -n "$SUMMARY" ] || auto_die "--evidence-summary is required"
auto_is_known_evidence_class "$EVIDENCE_CLASS" || auto_die "unknown evidence class: $EVIDENCE_CLASS"
auto_is_strong_evidence_class "$EVIDENCE_CLASS" || auto_die "optimize-one requires a strong evidence class, got: $EVIDENCE_CLASS"

REPO_ROOT="$(auto_repo_root)"
SKILL_DIR="$REPO_ROOT/codex/skills/$SKILL"
cd "$REPO_ROOT"

[ -f "$SKILL_DIR/SKILL.md" ] || auto_die "skill not found: $SKILL"
if auto_is_protected_path "$SKILL_DIR"; then
  auto_die "protected skill is ineligible for autonomous optimization: $SKILL"
fi

BRANCH="auto/$SKILL/$PROBLEM_SLUG"
BASE_BRANCH="${AUTO_BASE_BRANCH:-main}"

printf '# auto optimize-one %s\n' "$PHASE"
printf 'starting_status:\n'
git status --porcelain
printf '\n'

case "$PHASE" in
  prepare)
    worktree_dirty="$(git status --porcelain || true)"
    if [ -n "$worktree_dirty" ]; then
      printf 'prepare_dirty_worktree_blocker:\n%s\n' "$worktree_dirty" >&2
      exit 1
    fi
    printf 'checking_duplicate_surfaces:\n'
    git branch --list 'auto/*' || true
    git branch -r --list 'origin/auto/*' || true
    if auto_have gh; then
      gh pr list --state open --head "$BRANCH" || true
      gh pr list --state closed --search "$BRANCH" --limit 10 || true
    else
      printf 'gh_unavailable=true\n'
    fi
    git log --oneline --all --grep="$BRANCH" -n 10 || true
    if auto_branch_exists "$BRANCH" || auto_remote_branch_exists "$BRANCH"; then
      auto_die "duplicate branch exists: $BRANCH"
    fi
    if ! git show-ref --verify --quiet "refs/heads/$BASE_BRANCH"; then
      auto_die "base branch not found: $BASE_BRANCH"
    fi
    current_branch="$(git branch --show-current)"
    if [ "$current_branch" != "$BASE_BRANCH" ]; then
      auto_die "prepare must start from $BASE_BRANCH before creating $BRANCH, got ${current_branch:-detached HEAD}"
    fi
    git switch -c "$BRANCH" "$BASE_BRANCH"
    cat <<EOF_PREPARE

## refine handoff
target_skill: $SKILL
evidence_class: $EVIDENCE_CLASS
sanitized_evidence_summary: $SUMMARY
branch: $BRANCH

Read:
- codex/skills/$SKILL/SKILL.md
- codex/skills/$SKILL/AUTO.md if present

Then use \$refine to make the smallest useful edit. Keep changes under codex/skills/$SKILL.
EOF_PREPARE
    ;;
  finalize)
    current_branch="$(git branch --show-current)"
    if [ "$current_branch" != "$BRANCH" ]; then
      auto_die "finalize must run on prepared branch: expected $BRANCH, got ${current_branch:-detached HEAD}"
    fi
    if ! git show-ref --verify --quiet "refs/heads/$BASE_BRANCH"; then
      auto_die "base branch not found: $BASE_BRANCH"
    fi
    target_root="codex/skills/$SKILL"
    target_changes_found=0
    non_target_paths=""
    append_non_target_path() {
      non_target_paths="${non_target_paths}${1}"$'\n'
    }
    path_is_target() {
      case "$1" in
        "$target_root"|"$target_root"/*) return 0 ;;
        *) return 1 ;;
      esac
    }
    classify_path() {
      if path_is_target "$1"; then
        target_changes_found=1
      else
        append_non_target_path "$1"
      fi
    }
    classify_pair() {
      local old_path="$1"
      local new_path="$2"
      if path_is_target "$old_path" && path_is_target "$new_path"; then
        target_changes_found=1
      else
        append_non_target_path "$old_path -> $new_path"
      fi
    }
    while IFS= read -r diff_line; do
      [ -n "$diff_line" ] || continue
      status="${diff_line%%$'\t'*}"
      path="${diff_line#*$'\t'}"
      case "$status" in
        R*|C*)
          old_path="${path%%$'\t'*}"
          new_path="${path#*$'\t'}"
          classify_pair "$old_path" "$new_path"
          ;;
        *)
          classify_path "$path"
          ;;
      esac
    done < <(git diff --name-status -M -C "$BASE_BRANCH"...HEAD)
    while IFS= read -r status_line; do
      [ -n "$status_line" ] || continue
      path="${status_line#???}"
      case "$path" in
        *" -> "*)
          old_path="${path%% -> *}"
          new_path="${path#* -> }"
          classify_pair "$old_path" "$new_path"
          ;;
        *)
          classify_path "$path"
          ;;
      esac
    done < <(git status --porcelain)
    if [ -n "$non_target_paths" ]; then
      printf 'non_target_change_blocker:\n%s\n' "$non_target_paths" >&2
      auto_die "non-target changes present; isolate or clean worktree before finalize"
    fi
    if [ "$target_changes_found" -eq 0 ]; then
      auto_die "no target skill changes found under codex/skills/$SKILL"
    fi
    if ! "$SCRIPT_DIR/auto-validate-corpus" codex/skills; then
      if [ "$REPAIR_ATTEMPTED" -eq 0 ]; then
        cat <<'EOF_REPAIR'
validation_result=failed
repair_allowed=true
Use $refine for one repair pass, then rerun finalize with --repair-attempted.
EOF_REPAIR
        exit 1
      fi
      auto_die "validation failed after repair; leaving target changes in place because owned edits cannot be proven"
    fi
    cat <<EOF_FINALIZE
validation_result=passed
target_skill: $SKILL
evidence_class: $EVIDENCE_CLASS
sanitized_evidence_summary: $SUMMARY
auto_md_existed: $([ -f "$SKILL_DIR/AUTO.md" ] && printf yes || printf no)
branch: $BRANCH

Use \$ship to create or update a PR with sanitized proof. Then use \$fin only if all guardrails pass.
EOF_FINALIZE
    ;;
  *)
    usage
    exit 2
    ;;
esac
