#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: tune-scaffold --skill <skill> [options]

Prints a $tune source declaration, evidence command set, evidence ledger skeleton,
and refinement-brief skeleton.

Required:
  --skill <skill>                  Target skill name.

Options:
  --mode <mode>                    audit-only | proposal-only | apply-with-refine. Default: proposal-only.
  --goal <text>                    One-line tuning goal.
  --evidence-source <source>       in-flight | history | provided | worktree | mixed. Default: history.
  --history-scope <scope>          recent | arbitrary | explicit-sessions. Default: recent.
  --root <sessions-root>           Sessions root for history source. Default: ~/.codex/sessions.
  --since <iso8601>                Start timestamp for history source.
  --last <duration>                Recent duration for skill-success-rank. Default: 90d for recent history.
  --session-id <id>                Add explicit session-detail evidence. Repeatable.
  --failure-phrase <phrase>        Add targeted message-search evidence. Repeatable.
  --trigger-phrase <phrase>        Alias for --failure-phrase. Repeatable.
  --command-pattern <fragment>     Add targeted tool-search evidence. Repeatable.
  --workflow <name>                Add workflow-audit evidence. Repeatable.
  --workdir <path-fragment>        Add workdir-report evidence.
  -h, --help                       Show this help.

This helper scaffolds deterministic evidence collection only. $tune still owns source
selection, diagnosis, gap classification, mode decisions, whether $refine may apply
an edit, and whether publishing is authorized.
USAGE
}

skill=""
mode="proposal-only"
goal="<one-line goal>"
evidence_source="history"
history_scope="recent"
root="$HOME/.codex/sessions"
last="90d"
since=""
last_provided="no"
workdir=""
failure_phrases=()
command_patterns=()
workflows=()
session_ids=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --skill) skill="${2:-}"; shift 2 ;;
    --mode) mode="${2:-}"; shift 2 ;;
    --goal) goal="${2:-}"; shift 2 ;;
    --evidence-source|--source) evidence_source="${2:-}"; shift 2 ;;
    --history-scope) history_scope="${2:-}"; shift 2 ;;
    --root) root="${2:-}"; shift 2 ;;
    --since) since="${2:-}"; shift 2 ;;
    --last) last="${2:-}"; last_provided="yes"; shift 2 ;;
    --session-id) session_ids+=("${2:-}"); history_scope="explicit-sessions"; shift 2 ;;
    --failure-phrase|--trigger-phrase) failure_phrases+=("${2:-}"); shift 2 ;;
    --command-pattern) command_patterns+=("${2:-}"); shift 2 ;;
    --workflow) workflows+=("${2:-}"); shift 2 ;;
    --workdir) workdir="${2:-}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "unknown argument: $1" >&2; usage >&2; exit 2 ;;
  esac
done

if [[ -z "$skill" ]]; then
  echo "--skill is required" >&2
  usage >&2
  exit 2
fi

case "$mode" in
  audit-only|proposal-only|apply-with-refine) ;;
  *) echo "invalid --mode: $mode" >&2; echo "expected: audit-only | proposal-only | apply-with-refine" >&2; exit 2 ;;
esac

case "$evidence_source" in
  in-flight|history|provided|worktree|mixed) ;;
  *) echo "invalid --evidence-source: $evidence_source" >&2; echo "expected: in-flight | history | provided | worktree | mixed" >&2; exit 2 ;;
esac

case "$history_scope" in
  recent|arbitrary|explicit-sessions) ;;
  *) echo "invalid --history-scope: $history_scope" >&2; echo "expected: recent | arbitrary | explicit-sessions" >&2; exit 2 ;;
esac

needs_history="no"
case "$evidence_source" in
  history|mixed) needs_history="yes" ;;
esac
if [[ ${#session_ids[@]} -gt 0 || ${#failure_phrases[@]} -gt 0 || ${#command_patterns[@]} -gt 0 || ${#workflows[@]} -gt 0 || -n "$workdir" ]]; then
  needs_history="yes"
fi

if [[ -z "$since" && "$needs_history" == "yes" && "$history_scope" == "recent" ]]; then
  if command -v python3 >/dev/null 2>&1; then
    since="$(TUNE_LAST="$last" python3 - <<'PY'
import os
import re
from datetime import datetime, timedelta, timezone
last = os.environ.get("TUNE_LAST", "90d")
match = re.fullmatch(r"(\d+)d", last)
days = int(match.group(1)) if match else 90
print((datetime.now(timezone.utc) - timedelta(days=days)).isoformat(timespec="seconds").replace("+00:00", "Z"))
PY
)"
  else
    since="<iso8601>"
  fi
elif [[ -z "$since" && "$needs_history" == "yes" ]]; then
  since="<iso8601-or-omit-if-command-supports-full-history>"
fi

shq() { printf '%q' "$1"; }

is_protected="no"
case "$skill" in
  seq|tune|refine|cron|ship|land|.system|.system/*) is_protected="yes" ;;
esac

apply_gate="blocked: mode is not apply-with-refine"
if [[ "$mode" == "apply-with-refine" ]]; then
  apply_gate="needs evidence, validation, and worktree checks before editing"
fi

q_root="$(shq "$root")"
q_skill="$(shq "$skill")"
q_last="$(shq "$last")"
q_since="$(shq "$since")"

cat <<TUNE_OUT
# \$tune scaffold for skill: $skill

## Scope

Goal: Tune $skill so that <intended behavior> better matches <observed or suspected usage pattern>.
Mode: $mode
Evidence source: $evidence_source
History scope: $history_scope
Apply gate: $apply_gate
Publish gate: commit requires explicit git/publish intent; push requires explicit remote-publish intent after validation and commit
Protected/self-target gate: $is_protected
User goal: $goal

## Evidence source descriptor

- Kind: $evidence_source
- Locator: <current conversation | $root | session id | workdir | repo | file/artifact | validation output>
- Scope: <current turn | current conversation | recent window | arbitrary history | explicit sessions | supplied evidence>
- Window: <${last:-duration}/$since/all/none>
- Access method: <current context | \$seq command | file read | tool output | user-provided text>
- Privacy constraint: summarize only unless raw excerpts are explicitly requested and safe
- Limitation: <what this source cannot prove>
TUNE_OUT

if [[ "$evidence_source" == "in-flight" || "$evidence_source" == "mixed" ]]; then
  cat <<'TUNE_OUT'

## In-flight evidence checklist

- Current user feedback: <summarized, not raw transcript unless explicitly allowed>
- Current assistant behavior or routing: <what happened in this conversation>
- Current tool/validation output: <result and limits>
- What in-flight evidence proves: <local/current claim>
- What it does not prove: historical recurrence or activation rates
TUNE_OUT
fi

if [[ "$needs_history" == "yes" ]]; then
  cat <<TUNE_OUT

## Historical evidence commands
TUNE_OUT

  if [[ "$history_scope" == "recent" || "$last_provided" == "yes" ]]; then
    printf '\nseq skill-success-rank --root %s --skill %s --mode sessions --last %s --format jsonl\n' "$q_root" "$q_skill" "$q_last"
  else
    printf '\n# skill-success-rank usually needs a duration; supply --last <duration> if this report needs ranked activation history.\n'
  fi

  printf 'seq skill-audit --root %s --skill %s --mode trend --since %s --format table\n' "$q_root" "$q_skill" "$q_since"
  printf 'seq skill-cohort --root %s --skill %s --since %s --format table\n' "$q_root" "$q_skill" "$q_since"
  printf 'seq skill-blocks --root %s --skill %s --history latest --format json\n' "$q_root" "$q_skill"
  printf 'seq skill-blocks --root %s --skill %s --history all --format jsonl\n' "$q_root" "$q_skill"
fi

if [[ ${#session_ids[@]} -gt 0 ]]; then
  printf '\n## Explicit session evidence\n\n'
  for sid in "${session_ids[@]}"; do
    [[ -z "$sid" ]] && continue
    printf 'seq session-detail --root %s --session-id %s --format markdown\n' "$q_root" "$(shq "$sid")"
    printf 'seq session-tooling --root %s --session-id %s --summary --group-by executable --format table\n' "$q_root" "$(shq "$sid")"
  done
fi

if [[ ${#failure_phrases[@]} -gt 0 ]]; then
  printf '\n## Targeted trigger/failure phrase searches\n\n'
  for phrase in "${failure_phrases[@]}"; do
    [[ -z "$phrase" ]] && continue
    printf 'seq message-search --root %s --contains %s --roles user,assistant --limit 50 --format jsonl\n' "$q_root" "$(shq "$phrase")"
    printf 'seq message-audit --root %s --contains %s --roles user,assistant --show-query --format json\n' "$q_root" "$(shq "$phrase")"
  done
fi

if [[ ${#command_patterns[@]} -gt 0 ]]; then
  printf '\n## Targeted tooling searches\n\n'
  for pattern in "${command_patterns[@]}"; do
    [[ -z "$pattern" ]] && continue
    printf 'seq tool-search --root %s --contains %s --mode rows --format table\n' "$q_root" "$(shq "$pattern")"
    printf 'seq tool-search --root %s --contains %s --mode args --format jsonl\n' "$q_root" "$(shq "$pattern")"
  done
fi

if [[ ${#workflows[@]} -gt 0 ]]; then
  printf '\n## Targeted workflow audits\n\n'
  for workflow in "${workflows[@]}"; do
    [[ -z "$workflow" ]] && continue
    printf 'seq workflow-audit --root %s --workflow %s --mode report --since %s --format markdown\n' "$q_root" "$(shq "$workflow")" "$q_since"
  done
fi

if [[ -n "$workdir" ]]; then
  printf '\n## Targeted workdir evidence\n\n'
  printf 'seq workdir-report --root %s --contains %s --mode sessions --limit 20 --format table\n' "$q_root" "$(shq "$workdir")"
fi

cat <<TUNE_OUT

## Evidence ledger skeleton

- Entry 1:
  - Source kind: <in-flight | history | provided | worktree>
  - Command, locator, or source: <command/source>
  - Why this source was chosen: <reason>
  - What it proves: <supported claim>
  - What it does not prove: <limits>
  - Evidence class: <class>
  - Confidence: high | medium | low
  - Scope/window: <scope>
  - Recurrence: <count/window or unknown>
  - Counterevidence: <counter-signal or none found>
  - Sanitization note: <what was omitted or generalized>

## Refinement brief skeleton

Target skill: $skill

Mode:
- $mode

Evidence sources:
- Kind: $evidence_source
- Scope: $history_scope
- Locator: <current conversation | $root | session id | workdir | repo | file/artifact | validation output>
- Limitation: <what this source cannot prove>

Apply gate:
- <pass | blocked: reason>

Commit/push policy:
- Apply/edit/patch authorizes local file changes and validation only.
- Commit authorization: <none | explicit commit/publish/save-to-git request>
- Push authorization: <none | explicit push/remote-publish request>
- Failed validation, pre-commit, or worktree checks must produce a specific blocked publication state.

Tuning goal:
- $goal

Intended-use contract:
- Purpose: <summary>
- Trigger boundary: <summary>
- Anti-triggers / non-goals: <summary>
- Workflow expectation: <summary>
- Tool/resource expectation: <summary>
- Validation expectation: <summary>
- Companion-skill handoffs: <summary>
- Upgrade boundaries: <summary>

Observed usage:
- Summary: <sanitized finding>
- Recurrence: <frequency or recurrence summary, if known>
- Counterevidence: <anything that weakens the finding>

Gap:
- Type: <activation | interpretation | workflow | tooling | resource | validation | metadata | boundary | source-scope>
- Diagnosis: <specific mismatch>
- Severity: high | medium | low
- Risk if unchanged: <consequence>
- Risk of proposed change: <consequence>

Recommended \$refine action:
- <smallest sufficient edit or upgrade>

Must not change:
- <core behavior, companion boundary, trigger scope, or data-source assumptions to preserve>

Success criteria:
- <criterion 1>
- <criterion 2>
- <criterion 3>

Outcome observation:
- <future or current query that can observe the intended decision delta, when applicable>

Publishing, apply-with-refine only:
- Authorization: <none | commit-only | commit-and-push>, with exact user intent source.
- Atomic change boundary: <what this commit contains and why it is one coherent change>
- Scoped files to stage: <files justified by the brief>
- Unrelated worktree changes: <none | present and left unstaged | blocked because inseparable>
- Commit command/result: <blocked:not-requested | blocked:pre-commit-failed | blocked:worktree-inseparable | git commit -m "Tune $skill: <short gap/fix summary>" -> sha>
- Push command/result: <blocked:not-requested | blocked:pre-commit-failed | blocked:worktree-inseparable | blocked:commit-failed | git push result>
TUNE_OUT
