#!/usr/bin/env -S uv run python
"""Validate the repaired $opt -> $tune -> $refine ownership chain."""
from __future__ import annotations

import argparse
import json
from pathlib import Path
import re
import sys


def load_registry(path: Path) -> dict:
    return json.loads(path.read_text(encoding="utf-8"))


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--root", default="codex")
    parser.add_argument("--skill", default="opt")
    parser.add_argument("--registry", default="codex/control-plane/registry.yaml")
    args = parser.parse_args()

    root = Path(args.root)
    repo = root.parent.resolve()
    registry_path = (repo / args.registry).resolve() if not Path(args.registry).is_absolute() else Path(args.registry)
    registry = load_registry(registry_path)
    errors: list[str] = []

    opt_dir = root / "skills" / args.skill
    required = [
        opt_dir / "SKILL.md",
        opt_dir / "agents" / "openai.yaml",
        opt_dir / "references" / "routing-matrix.md",
        opt_dir / "references" / "delegation-prompts.md",
        root / "skills" / "tune" / "SKILL.md",
        root / "skills" / "refine" / "SKILL.md",
    ]
    for path in required:
        if not path.is_file():
            errors.append(f"missing:{path}")

    opt = registry.get("skills", {}).get("opt", {})
    if opt.get("activation") != "explicit_intent":
        errors.append(f"opt-activation:{opt.get('activation')}")
    if set(opt.get("handoffs_to", [])) < {"seq", "shadow", "tune", "refine"}:
        errors.append("opt-handoffs")

    openai = opt_dir / "agents" / "openai.yaml"
    if openai.exists() and not re.search(r"allow_implicit_invocation:\s*false", openai.read_text(encoding="utf-8")):
        errors.append("opt-interface-must-disable-runtime-implicit-invocation")

    forbidden = "skill" + "-optimizer"
    legacy_file = root / "agents" / (forbidden + ".toml")
    if legacy_file.exists():
        errors.append(f"superseded-writer-present:{legacy_file}")
    for path in root.rglob("*"):
        if not path.is_file() or "control-plane" in path.parts:
            continue
        if path.suffix not in {".md", ".yaml", ".yml", ".toml", ".py", ".sh"} and path.name != "opt-sanity":
            continue
        try:
            text = path.read_text(encoding="utf-8")
        except UnicodeDecodeError:
            continue
        if forbidden in text:
            errors.append(f"superseded-route-reference:{path}")

    opt_text = (opt_dir / "SKILL.md").read_text(encoding="utf-8") if (opt_dir / "SKILL.md").exists() else ""
    for phrase in ("$refine   sole skill-package writer", "No apply without a complete refine brief"):
        if phrase not in opt_text:
            errors.append(f"missing-contract:{phrase}")

    result = {"opt_sanity": {"verdict": "pass" if not errors else "fail", "errors": errors}}
    print(json.dumps(result, indent=2, sort_keys=True))
    return 0 if not errors else 2


if __name__ == "__main__":
    raise SystemExit(main())
