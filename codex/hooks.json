{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.dotfiles/codex/hooks/st_session_start.sh",
            "timeoutSec": 10,
            "statusMessage": "Hydrating $st plan"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.dotfiles/codex/hooks/st_pre_tool_use.sh",
            "timeoutSec": 10,
            "statusMessage": "Checking $st plan sync"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "LEARNINGS_STOP_MODE=block $HOME/.dotfiles/codex/hooks/learnings_stop.sh",
            "timeoutSec": 10,
            "statusMessage": "Checking learnings checkpoint"
          }
        ]
      }
    ]
  }
}
