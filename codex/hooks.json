{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.dotfiles/codex/hooks/st_session_start.sh",
            "timeoutSec": 10,
            "statusMessage": "Hydrating $st plan"
          }
        ]
      }
    ]
  }
}
