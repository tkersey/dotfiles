{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "^(startup|resume)$",
        "hooks": [
          {
            "type": "command",
            "command": "LEARNINGS_SESSIONSTART_LIMIT=5 /Users/tk/.dotfiles/codex/hooks/learnings_session_start.sh",
            "timeoutSec": 10,
            "statusMessage": "Loading repo learnings"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "LEARNINGS_STOP_MODE=block /Users/tk/.dotfiles/codex/hooks/learnings_stop.sh",
            "timeoutSec": 10,
            "statusMessage": "Checking learnings checkpoint"
          }
        ]
      }
    ]
  }
}
